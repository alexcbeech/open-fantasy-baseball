NEXT_PUBLIC_APP_NAME="Open Fantasy Baseball"
DATABASE_URL="postgresql://ofb:ofb@localhost:5432/ofb"
DATABASE_POOL_MAX="10"
REDIS_URL="redis://localhost:6379"
MLB_STATS_API_BASE_URL="https://statsapi.mlb.com/api/v1"
NEON_AUTH_BASE_URL=""
NEON_AUTH_COOKIE_SECRET=""
# Account creation is closed by default while OFB is in progress.
# Set to "true" to re-enable sign-ups. Sign-in and existing accounts are unaffected.
ALLOW_SIGNUPS=""
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:ops@openfantasybaseball.local"
# Promote user feedback to GitHub issues from /admin. Token needs issues:write
# on the target repo; scrubbed message + page path only (no reporter email).
GITHUB_TOKEN=""
GITHUB_FEEDBACK_REPO="alexcbeech/open-fantasy-baseball"
# League invite emails via Resend (https://resend.com). Leave empty to disable
# sending: invites still work, the commissioner just shares the join link
# manually. RESEND_FROM_EMAIL must use a domain verified in Resend,
# e.g. "OFB <invites@mail.example.com>".
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
# Canonical https URL used in emailed links; falls back to the request origin.
APP_BASE_URL=""
